[
  {
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 5,
	"margin": "6 6 0 6",
    "modules-left": [
      "niri/window",
	  "niri/workspaces"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "tray",
      "mpd",
      "temperature",
      "cpu",
      "memory",
      "network",
      "pulseaudio",
      "backlight",
      "keyboard-state",
      "battery",
      "battery#bat2",
    ],
    "niri/window": {
      "format": "{title}",
      "max-length": 20,
      "rewrite": {
        "^(?!.*\\S).*": "Finder"
      }
    },
	"niri/workspaces": {
    	"active-only": false,
    	"all-outputs": true,
    	"format": "{index}",
    	"on-click": "activate",
	},
    "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
        "locked": "яАг",
        "unlocked": "яВЬ"
      }
    },
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
        "",
        "яЛТ"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },
    "mpd": {
      "format": "яАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
      "format-disconnected": "яАБ Disconnected",
      "format-stopped": "яАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
      "unknown-tag": "N/A",
      "interval": 2,
      "consume-icons": {
        "on": "яГД "
      },
      "random-icons": {
        "on": "яБ┤ "
      },
      "repeat-icons": {
        "on": "яАЮ "
      },
      "single-icons": {
        "on": "яАЮ1 "
      },
      "state-icons": {
        "paused": "яБМ",
        "playing": "яБЛ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)",
      "on-click": "mpc toggle",
      "on-click-right": "foot -a ncmpcpp ncmpcpp",
      "on-scroll-up": "mpc volume +2",
      "on-scroll-down": "mpc volume -2"
    },
    "tray": {
      "spacing": 10
    },
    "clock": {
      "format": "{:%a %b %d %H:%M}",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
      "format": "яЛЫ  {usage}%"
    },
    "memory": {
      "format": "яГЙ {}%"
    },
    "temperature": {
      "thermal-zone": 2,
      "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": [
        "яЭл",
        "яЛЙ",
        "яЭй"
      ]
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "юОН",
        "юПУ",
        "юПС",
        "юПП",
        "юПО",
        "юПН",
        "юПК",
        "юПИ",
        "юОЫ"
      ]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-charging": "яЧз {capacity}%",
      "format-plugged": "яЗж {capacity}%",
      "format-icons": [
        "яЙД",
        "яЙГ",
        "яЙВ",
        "яЙБ",
        "яЙА"
      ]
    },
    "battery#bat2": {
      "bat": "BAT2"
    },
    "network": {
      "format-wifi": "{essid} яЗл ",
      "format-ethernet": "яЮЦ {ifname}",
      "tooltip-format": "яЮЦ {ifname} via {gwaddr}",
      "format-linked": "яЮЦ {ifname} (No IP)",
      "format-disconnected": "Disconnected тЪа {ifname}",
      "format-alt": "яЮЦ {ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon}  {volume}% {format_source}",
      "format-bluetooth": "яКФ {icon} {volume}% {format_source}",
      "format-bluetooth-muted": "яЪй яКФ {icon} {format_source}",
      "format-muted": "яЪй  {format_source}",
      "format-source": "яД░ {volume}%",
      "format-source-muted": "яД▒",
      "format-icons": {
        "default": [
          "яАж",
          "яАз",
          "яАи"
        ]
      },
      "on-click": "pavucontrol",
      "on-click-right": "foot -a pw-top pw-top"
    }
  }
]
